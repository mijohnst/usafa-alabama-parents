# Prevent direct web access to internal PHP files
<FilesMatch "^(config|auth|mailer|lib)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Increase upload limits (mod_php)
php_value post_max_size 256M
php_value upload_max_filesize 100M
php_value memory_limit 256M
php_value max_execution_time 300
php_value max_input_time 600
